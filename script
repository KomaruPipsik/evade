-- Функция переключения (вызывается ПОСЛЕ того как tabBtns и tabFrames заполнены)
local function switchTab(name)
	if activeTab == name then return end
	activeTab = name
	for _, n in ipairs(tabNames) do
		local isActive = (n == name)
		tabFrames[n].Visible = isActive
		if isActive then
			tabBtns[n].ind.Size = UDim2.new(0.7,0,0,2)
			tabBtns[n].ind.Position = UDim2.new(0.15,0,1,-2)
			tabBtns[n].btn.TextColor3 = Color3.fromRGB(100,180,255)
		else
			tabBtns[n].ind.Size = UDim2.new(0,0,0,2)
			tabBtns[n].ind.Position = UDim2.new(0.5,0,1,-2)
			tabBtns[n].btn.TextColor3 = Color3.fromRGB(140,145,160)
		end
	end
end

