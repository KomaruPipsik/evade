-- Input Handler
UserInputService.InputBegan:Connect(function(inp, gpe)
	if gpe then return end

	-- CapsLock → авто-прыжок
	if inp.KeyCode == Enum.KeyCode.CapsLock then
		State.AutoJump = not State.AutoJump
		updateStatusOverlay()
		notify(State.AutoJump and "Авто-прыжок: ВКЛ" or "Авто-прыжок: ВЫКЛ")
		return
	end

	-- V → запись
	if inp.KeyCode == RecordKeybind then
		if not State.Recording then
			State.Recording = true; RecordedFrames = {}
			local rs = _G._AP_recStatus
			if rs then rs.TextColor3 = Color3.fromRGB(200,60,60); rs.Text = "⏺ Запись... (V — стоп)" end
			notify("Запись начата — V остановить", Color3.fromRGB(200,60,60))
		else
			State.Recording = false; State.HasRecord = #RecordedFrames > 0
			local rs = _G._AP_recStatus
			if rs then rs.TextColor3 = Color3.fromRGB(55,200,100)
				rs.Text = "✔ Готово (" .. #RecordedFrames .. " кадров)  B — воспроизвести" end
			notify("Запись сохранена! " .. #RecordedFrames .. " кадров", Color3.fromRGB(55,200,100))
		end
		return
	end

	-- B → воспроизвести
	if inp.KeyCode == ReplayKeybind and State.HasRecord and not ReplayActive then
		ReplayActive = true
		local rs = _G._AP_recStatus
		if rs then rs.TextColor3 = Color3.fromRGB(70,140,255); rs.Text = "▶ Воспроизведение..." end
		notify("Ghost Replay: старт", Color3.fromRGB(70,140,255))
		task.spawn(function()
			local char = getChar()
			local hum2 = char and char:FindFirstChild("Humanoid")
			local savedWS = hum2 and hum2.WalkSpeed or 16
			local savedJP = hum2 and hum2.JumpPower  or 50
			if hum2 then hum2.WalkSpeed = 0; hum2.JumpPower = 0 end
			for _, frame in ipairs(RecordedFrames) do
				if not ReplayActive then break end
				local root2 = getChar() and getChar():FindFirstChild("HumanoidRootPart")
				if root2 then root2.CFrame = frame.CFrame end
				task.wait(frame.dt)
			end
			ReplayActive = false
			if hum2 then hum2.WalkSpeed = savedWS; hum2.JumpPower = savedJP end
			if rs then rs.TextColor3 = Color3.fromRGB(55,200,100); rs.Text = "✔ Завершено   B — повторить" end
			notify("Ghost Replay: завершён", Color3.fromRGB(55,200,100))
		end)
	end
end)

