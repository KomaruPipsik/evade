	stripe.BackgroundColor3 = Color3.fromRGB(70, 140, 255)
	stripe.BackgroundTransparency = 1; stripe.BorderSizePixel = 0; stripe.ZIndex = 2
	stripe.Parent = row; Instance.new("UICorner").Parent = stripe

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(0.6, 0, 0, 18); lbl.Position = UDim2.new(0, 12, 0, 7)
	lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.fromRGB(185, 190, 215)
	lbl.TextSize = 12; lbl.Font = Enum.Font.GothamSemibold; lbl.Text = label
	lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.ZIndex = 2; lbl.Parent = row

	local descL = Instance.new("TextLabel")
	descL.Size = UDim2.new(0.72, 0, 0, 14); descL.Position = UDim2.new(0, 12, 0, 27)
	descL.BackgroundTransparency = 1; descL.TextColor3 = Color3.fromRGB(80, 85, 108)
	descL.TextSize = 10; descL.Font = Enum.Font.Gotham; descL.Text = desc
	descL.TextXAlignment = Enum.TextXAlignment.Left; descL.TextWrapped = true
	descL.ZIndex = 2; descL.Parent = row

	-- Switch background
	local swBg = Instance.new("Frame")
	swBg.Size = UDim2.new(0, 38, 0, 20); swBg.Position = UDim2.new(1, -48, 0.5, -10)
	swBg.BackgroundColor3 = Color3.fromRGB(34, 34, 46); swBg.BorderSizePixel = 0
	swBg.ZIndex = 3; swBg.Parent = row; Instance.new("UICorner").Parent = swBg

	local knob = Instance.new("Frame")
	knob.Size = UDim2.new(0, 14, 0, 14); knob.Position = UDim2.new(0, 3, 0.5, -7)
	knob.BackgroundColor3 = Color3.fromRGB(115, 120, 148); knob.BorderSizePixel = 0
	knob.ZIndex = 4; knob.Parent = swBg; Instance.new("UICorner").Parent = knob

	-- кнопка ТОЛЬКО на области свитча
	local swBtn = Instance.new("TextButton")
	swBtn.Size = UDim2.new(1, 0, 1, 0); swBtn.BackgroundTransparency = 1
	swBtn.Text = ""; swBtn.AutoButtonColor = false; swBtn.ZIndex = 5; swBtn.Parent = swBg

	-- невидимая кнопка на весь ряд (только hover)
	local rowBtn = Instance.new("TextButton")
	rowBtn.Size = UDim2.new(1, 0, 1, 0); rowBtn.BackgroundTransparency = 1
	rowBtn.Text = ""; rowBtn.AutoButtonColor = false; rowBtn.ZIndex = 2; rowBtn.Parent = row

	local enabled = false
	local function doToggle()
		enabled = not enabled
		if enabled then
			tw(swBg,   {BackgroundColor3 = Color3.fromRGB(50, 130, 255)}, 0.2)
			tw(knob,   {Position = UDim2.new(1, -17, 0.5, -7), BackgroundColor3 = Color3.fromRGB(255, 255, 255)}, 0.2)
			tw(stripe, {BackgroundTransparency = 0}, 0.18)
			tw(lbl,    {TextColor3 = Color3.fromRGB(220, 225, 245)}, 0.18)
			tw(row,    {BackgroundColor3 = Color3.fromRGB(19, 22, 38)}, 0.18)
		else
			tw(swBg,   {BackgroundColor3 = Color3.fromRGB(34, 34, 46)}, 0.2)
			tw(knob,   {Position = UDim2.new(0, 3, 0.5, -7), BackgroundColor3 = Color3.fromRGB(115, 120, 148)}, 0.2)
			tw(stripe, {BackgroundTransparency = 1}, 0.18)
			tw(lbl,    {TextColor3 = Color3.fromRGB(185, 190, 215)}, 0.18)
			tw(row,    {BackgroundColor3 = Color3.fromRGB(19, 19, 26)}, 0.18)
		end
		onToggle(enabled)
	end

	swBtn.MouseButton1Click:Connect(doToggle)
	rowBtn.MouseButton1Click:Connect(doToggle)

	rowBtn.MouseEnter:Connect(function()
		tw(row, {BackgroundColor3 = enabled
			and Color3.fromRGB(21, 25, 42)
			or  Color3.fromRGB(22, 22, 30)}, 0.12)
	end)
	rowBtn.MouseLeave:Connect(function()
		tw(row, {BackgroundColor3 = enabled
			and Color3.fromRGB(19, 22, 38)
			or  Color3.fromRGB(19, 19, 26)}, 0.12)
	end)

	return row, function() return enabled end
end

