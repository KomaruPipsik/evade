	-- ФИКСИРОВАННАЯ позиция: каждая кнопка ровно 25% ширины
	btn.Size = UDim2.new(0.25, 0, 1, 0)
	btn.Position = UDim2.new(0.25 * (i - 1), 0, 0, 0)
	btn.BackgroundTransparency = 1
	btn.Text = name; btn.TextColor3 = Color3.fromRGB(100, 105, 128)
	btn.TextSize = 12; btn.Font = Enum.Font.SourceSansSemibold
	btn.ZIndex = 6; btn.AutoButtonColor = false; btn.Parent = navBar
