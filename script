	btn.Font = Enum.Font.SourceSansBold; btn.BorderSizePixel = 0
	btn.AutoButtonColor = false; btn.ZIndex = 2; btn.Parent = row
	Instance.new("UICorner").Parent = btn
	BindBtnRefs[bindKey] = btn
	local listening = false
	btn.MouseButton1Click:Connect(function()
		if listening then return end
		listening = true; btn.Text = "..."
		tw(btn, {BackgroundColor3 = Color3.fromRGB(42, 48, 80)}, 0.1)
		local conn
		conn = UserInputService.InputBegan:Connect(function(inp, gpe)
			if gpe then return end
			local b = nil
			if inp.UserInputType == Enum.UserInputType.Keyboard then
				b = {type = "key", value = inp.KeyCode}
			else
				for _, mt in ipairs(MOUSE_TYPES) do
					if inp.UserInputType == mt then b = {type = "mouse", value = mt} break end
				end
			end
			if b then
				conn:Disconnect(); listening = false
				Keybinds[bindKey] = b; btn.Text = bindName(b)
				tw(btn, {BackgroundColor3 = Color3.fromRGB(28, 32, 52)}, 0.1)
				notify("Клавиша: " .. bindName(b))
			end
		end)
	end)
	btn.MouseEnter:Connect(function() if not listening then tw(btn, {BackgroundColor3 = Color3.fromRGB(34, 40, 64)}, 0.1) end end)
	btn.MouseLeave:Connect(function() if not listening then tw(btn, {BackgroundColor3 = Color3.fromRGB(28, 32, 52)}, 0.1) end end)
end

