local function makeSlider(parent, label, min, max, default, unit, onChange, order)
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1,0,0,60)
	row.BackgroundColor3 = Color3.fromRGB(26,26,32)
	row.BorderSizePixel = 0
	row.LayoutOrder = order or 0
	row.Parent = parent
	Instance.new("UICorner").Parent = row

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(0.6,0,0,20)
	lbl.Position = UDim2.new(0,12,0,6)
	lbl.BackgroundTransparency = 1
	lbl.TextColor3 = Color3.fromRGB(210,215,230)
	lbl.TextSize = 12
	lbl.Font = Enum.Font.GothamSemibold
	lbl.Text = label
	lbl.TextXAlignment = Enum.TextXAlignment.Left
	lbl.Parent = row

	local valLbl = Instance.new("TextLabel")
	valLbl.Size = UDim2.new(0.35,0,0,20)
	valLbl.Position = UDim2.new(0.63,0,0,6)
	valLbl.BackgroundTransparency = 1
	valLbl.TextColor3 = Color3.fromRGB(100,180,255)
	valLbl.TextSize = 12
	valLbl.Font = Enum.Font.GothamBold
	valLbl.Text = tostring(default) .. (unit or "")
	valLbl.TextXAlignment = Enum.TextXAlignment.Right
	valLbl.Parent = row

	local defLbl = Instance.new("TextLabel")
	defLbl.Size = UDim2.new(1,-24,0,14)
	defLbl.Position = UDim2.new(0,12,0,46)
	defLbl.BackgroundTransparency = 1
	defLbl.TextColor3 = Color3.fromRGB(90,95,110)
	defLbl.TextSize = 10
	defLbl.Font = Enum.Font.Gotham
	defLbl.Text = "По умолчанию: " .. tostring(default)
	defLbl.TextXAlignment = Enum.TextXAlignment.Left
	defLbl.Parent = row

	local track = Instance.new("Frame")
	track.Size = UDim2.new(1,-24,0,6)
	track.Position = UDim2.new(0,12,0,30)
	track.BackgroundColor3 = Color3.fromRGB(45,45,55)
	track.BorderSizePixel = 0
	track.Parent = row
	Instance.new("UICorner").Parent = track

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new((default-min)/(max-min),0,1,0)
	fill.BackgroundColor3 = Color3.fromRGB(80,160,255)
	fill.BorderSizePixel = 0
	fill.Parent = track
	Instance.new("UICorner").Parent = fill

	local thumb = Instance.new("Frame")
	thumb.Size = UDim2.new(0,14,0,14)
	thumb.Position = UDim2.new((default-min)/(max-min),0,0.5,-7)
	thumb.AnchorPoint = Vector2.new(0.5,0)
	thumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
	thumb.BorderSizePixel = 0
	thumb.ZIndex = 3
	thumb.Parent = track
	Instance.new("UICorner").Parent = thumb

	local dragging = false
	local currentVal = default

	local function updateSlider(absPos)
		local rel = math.clamp((absPos - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		currentVal = math.floor(min + rel*(max-min) + 0.5)
		valLbl.Text = tostring(currentVal) .. (unit or "")
		tween(fill, {Size = UDim2.new(rel,0,1,0)}, 0.05)
		tween(thumb, {Position = UDim2.new(rel,0,0.5,-7)}, 0.05)
		onChange(currentVal)
	end

	local clickArea = Instance.new("TextButton")
	clickArea.Size = UDim2.new(1,0,1,0)
	clickArea.BackgroundTransparency = 1
	clickArea.Text = ""
	clickArea.ZIndex = 4
	clickArea.Parent = track

	clickArea.MouseButton1Down:Connect(function()
		dragging = true
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			updateSlider(input.Position.X)
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
	clickArea.MouseButton1Up:Connect(function()
		updateSlider(UserInputService:GetMouseLocation().X)
	end)
end

