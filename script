local function tw(obj, props, t, style, dir)
	TweenService:Create(obj,
		TweenInfo.new(t or 0.22,
			style or Enum.EasingStyle.Quad,
			dir   or Enum.EasingDirection.Out),
		props):Play()
end

local function getChar() return Player.Character end

-- Уведомления (правый нижний угол)
local function notify(text, color)
	color = color or Color3.fromRGB(70, 140, 255)
	local sg = Instance.new("ScreenGui")
	sg.Name = "_Notif"; sg.ResetOnSpawn = false; sg.Parent = Player.PlayerGui

	local f = Instance.new("Frame")
	f.Size = UDim2.new(0, 260, 0, 44)
	f.Position = UDim2.new(1, 10, 1, -58)
	f.BackgroundColor3 = Color3.fromRGB(16, 16, 22)
	f.BorderSizePixel = 0; f.Parent = sg
	local fc = Instance.new("UICorner"); fc.CornerRadius = UDim.new(0, 8); fc.Parent = f

	-- цветная левая полоса
	local bar = Instance.new("Frame")
	bar.Size = UDim2.new(0, 3, 1, -8); bar.Position = UDim2.new(0, 0, 0, 4)
	bar.BackgroundColor3 = color; bar.BorderSizePixel = 0; bar.Parent = f
	Instance.new("UICorner").Parent = bar

	-- иконка
	local ico = Instance.new("TextLabel")
	ico.Size = UDim2.new(0, 20, 1, 0); ico.Position = UDim2.new(0, 7, 0, 0)
	ico.BackgroundTransparency = 1; ico.Text = "●"
	ico.TextColor3 = color; ico.TextSize = 10; ico.Font = Enum.Font.GothamBold
	ico.Parent = f

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(1, -32, 1, 0); lbl.Position = UDim2.new(0, 30, 0, 0)
	lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.fromRGB(205, 210, 228)
	lbl.TextSize = 12; lbl.Font = Enum.Font.GothamSemibold
	lbl.Text = text; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Parent = f

	tw(f, {Position = UDim2.new(1, -275, 1, -58)}, 0.28, Enum.EasingStyle.Back)
	task.delay(2.5, function()
		tw(f, {Position = UDim2.new(1, 10, 1, -58)}, 0.22)
		task.delay(0.25, function() sg:Destroy() end)
	end)
