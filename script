RunService.Heartbeat:Connect(function(dt)
	local char = getChar(); if not char then return end
	local hum  = char:FindFirstChild("Humanoid")
	local root = char:FindFirstChild("HumanoidRootPart")
	if not hum or not root then return end

	-- Запись
	if State.Recording then
		table.insert(RecordedFrames, {CFrame = root.CFrame, dt = dt})
	end

	-- Авто-прыжок (пассивный, от пола)
	if State.AutoJump and hum.FloorMaterial ~= Enum.Material.Air then
		local ray = workspace:Raycast(root.Position, Vector3.new(0, -CONFIG.AutoJumpThreshold, 0))
		if ray then
			hum:ChangeState(Enum.HumanoidStateType.Jumping)
			root.AssemblyLinearVelocity = Vector3.new(
				root.AssemblyLinearVelocity.X, CONFIG.AutoJumpHeight, root.AssemblyLinearVelocity.Z)
		end
	end

	-- Slope Bounce
	if State.SlopeBounce then
		local rayParams = RaycastParams.new()
		rayParams.FilterDescendantsInstances = {char}
		rayParams.FilterType = Enum.RaycastFilterType.Exclude
		local vel = root.AssemblyLinearVelocity
		local checkDist = CONFIG.SlopeBounceCheckDist
		local dirs = {
			Vector3.new(0, -checkDist, 0),
			Vector3.new(vel.X * 0.1, -checkDist, vel.Z * 0.1),
		}
		for _, dir in ipairs(dirs) do
			local hit = workspace:Raycast(root.Position, dir, rayParams)
			if hit then
				local normal = hit.Normal
				local angle = math.deg(math.acos(math.clamp(normal:Dot(Vector3.new(0,1,0)), -1, 1)))
				if angle >= CONFIG.SlopeMinAngle and angle <= CONFIG.SlopeMaxAngle then
					local dist = (root.Position - hit.Position).Magnitude
					if dist <= checkDist * 0.65 then
						local bounceDir = (normal + Vector3.new(0,1,0)).Unit
						root.AssemblyLinearVelocity = Vector3.new(
							bounceDir.X * CONFIG.SlopeBounceForce * 0.4,
							CONFIG.SlopeBounceForce,
							bounceDir.Z * CONFIG.SlopeBounceForce * 0.4
						)
						hum:ChangeState(Enum.HumanoidStateType.Jumping)
						break
					end
				end
			end
		end
	end

	-- Bunny Hop
	if State.BunnyHop and hum.FloorMaterial ~= Enum.Material.Air then
		hum:ChangeState(Enum.HumanoidStateType.Jumping)
	end

	-- Spinbot (BodyAngularVelocity — плавное вращение без дёрганья)
	if State.Spinbot then
		local bav = root:FindFirstChild("_SpinBAV")
		if not bav then
			bav = Instance.new("BodyAngularVelocity")
			bav.Name = "_SpinBAV"
			bav.MaxTorque = Vector3.new(0, math.huge, 0)
			bav.Parent = root
		end
		bav.AngularVelocity = Vector3.new(0, CONFIG.SpinSpeed, 0)
	else
		local bav = root:FindFirstChild("_SpinBAV")
		if bav then bav:Destroy() end
	end

	-- Fake Lag: визуальный рывок (task.defer - почти без задержки, не блокирует движение)
	if State.FakeLag then
		fakeLagTimer = fakeLagTimer + dt
		if fakeLagTimer >= 0.18 then
			fakeLagTimer = 0
			local savedVel = root.AssemblyLinearVelocity
			local savedCF  = root.CFrame
			root.CFrame = savedCF * CFrame.new(0, 0, 5)
			root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
			task.defer(function()
				local c2 = getChar()
				local r2 = c2 and c2:FindFirstChild("HumanoidRootPart")
				if r2 and State.FakeLag then
					r2.CFrame = savedCF
					r2.AssemblyLinearVelocity = savedVel
				end
			end)
		end
	end

	-- Rainbow Trail
	if State.RainbowTrail then
		if not trail or not trail.Parent then createTrail() end
		rainbowHue = (rainbowHue + dt * 0.35) % 1
		if trail then
			trail.Color = ColorSequence.new{
				ColorSequenceKeypoint.new(0, Color3.fromHSV(rainbowHue, 1, 1)),
				ColorSequenceKeypoint.new(1, Color3.fromHSV((rainbowHue + 0.5) % 1, 1, 1))
			}
		end
	else
		if trail and trail.Parent then trail:Destroy(); trail = nil end
	end

	-- Player ESP + Distance
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= Player and p.Character then
			local pChar = p.Character
			local pRoot = pChar:FindFirstChild("HumanoidRootPart")
			if State.PlayerESP then
				ensureHL(pChar, "_PlayerHL", Color3.fromRGB(50,150,255), Color3.fromRGB(90,190,255))
			else
				removeHL(pChar, "_PlayerHL")
			end
			if State.DistanceESP and pRoot then
				local bg = ensureDistBG(pChar)
				if bg then
					local dl = bg:FindFirstChild("D")
					if dl then dl.Text = math.floor((root.Position - pRoot.Position).Magnitude) .. "m" end
				end
			else
				if pRoot then local b = pRoot:FindFirstChild("_DistBG"); if b then b:Destroy() end end
			end
		end
	end
end)

