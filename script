local function makeSlider(parent, label, minV, maxV, default, unit, onChange, order)
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 52); row.BackgroundColor3 = Color3.fromRGB(19, 19, 26)
	row.BorderSizePixel = 0; row.LayoutOrder = order or 0; row.Parent = parent
	Instance.new("UICorner").Parent = row

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(0.55, 0, 0, 16); lbl.Position = UDim2.new(0, 10, 0, 4)
	lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.fromRGB(165, 170, 200)
	lbl.TextSize = 11; lbl.Font = Enum.Font.GothamSemibold; lbl.Text = label
	lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Parent = row

	local valLbl = Instance.new("TextLabel")
	valLbl.Size = UDim2.new(0.4, 0, 0, 16); valLbl.Position = UDim2.new(0.58, 0, 0, 4)
	valLbl.BackgroundTransparency = 1; valLbl.TextColor3 = Color3.fromRGB(70, 140, 255)
	valLbl.TextSize = 11; valLbl.Font = Enum.Font.GothamBold
	valLbl.Text = tostring(default) .. (unit or "")
	valLbl.TextXAlignment = Enum.TextXAlignment.Right; valLbl.Parent = row

	local defLbl = Instance.new("TextLabel")
	defLbl.Size = UDim2.new(1, -20, 0, 11); defLbl.Position = UDim2.new(0, 10, 0, 40)
	defLbl.BackgroundTransparency = 1; defLbl.TextColor3 = Color3.fromRGB(58, 62, 85)
	defLbl.TextSize = 9; defLbl.Font = Enum.Font.Gotham
	defLbl.Text = "По умолчанию: " .. tostring(default)
	defLbl.TextXAlignment = Enum.TextXAlignment.Left; defLbl.Parent = row

	local track = Instance.new("Frame")
	track.Size = UDim2.new(1, -20, 0, 5); track.Position = UDim2.new(0, 10, 0, 22)
	track.BackgroundColor3 = Color3.fromRGB(32, 35, 52); track.BorderSizePixel = 0
	track.Parent = row; Instance.new("UICorner").Parent = track

	local initRel = math.clamp((default - minV) / (maxV - minV), 0, 1)
	local fill = Instance.new("Frame")
	fill.Size = UDim2.new(initRel, 0, 1, 0); fill.BackgroundColor3 = Color3.fromRGB(55, 125, 255)
	fill.BorderSizePixel = 0; fill.Parent = track; Instance.new("UICorner").Parent = fill

	local thumb = Instance.new("Frame")
	thumb.Size = UDim2.new(0, 13, 0, 13)
	thumb.Position = UDim2.new(initRel, -6, 0.5, -6)
	thumb.BackgroundColor3 = Color3.fromRGB(240, 240, 255)
	thumb.BorderSizePixel = 0; thumb.ZIndex = 3; thumb.Parent = track
	Instance.new("UICorner").Parent = thumb

	local dragging = false
	local function update(absX)
		local rel = math.clamp((absX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		local val = math.floor(minV + rel * (maxV - minV) + 0.5)
		valLbl.Text = tostring(val) .. (unit or "")
		fill.Size = UDim2.new(rel, 0, 1, 0)
		thumb.Position = UDim2.new(rel, -6, 0.5, -6)
		onChange(val)
	end

	local area = Instance.new("TextButton")
	area.Size = UDim2.new(1, 0, 3, 0); area.Position = UDim2.new(0, 0, -1, 0)
	area.BackgroundTransparency = 1; area.Text = ""; area.ZIndex = 4; area.Parent = track

	area.MouseButton1Down:Connect(function()
		dragging = true
		tw(thumb, {Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(fill.Size.X.Scale, -8, 0.5, -8)}, 0.1)
	end)
	UserInputService.InputChanged:Connect(function(inp)
