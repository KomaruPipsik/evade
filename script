local function bindName(b)
	if not b then return "—" end
	if b.type == "key" then return b.value.Name end
	return MOUSE_NAMES[b.value] or "?"
end
local function bindMatches(b, inp)
	if not b then return false end
	if b.type == "key" and inp.UserInputType == Enum.UserInputType.Keyboard then
		return inp.KeyCode == b.value
	elseif b.type == "mouse" then
		return inp.UserInputType == b.value
	end
	return false
end

