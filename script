local rainbowHue  = 0
local trail       = nil
local fakeLagTimer= 0
local fakeLagSave = nil
local spinAngle   = 0

local function ensureHL(char, name, fill, outline)
	if not char or not char.Parent then return end
	local h = char:FindFirstChild(name)
	if not h then
		h = Instance.new("Highlight"); h.Name = name
		h.FillColor = fill; h.OutlineColor = outline
		h.FillTransparency = 0.55; h.OutlineTransparency = 0
		h.Adornee = char; h.Parent = char
	end
end

local function removeHL(char, name)
	if not char then return end; local h = char:FindFirstChild(name); if h then h:Destroy() end
end

local function ensureDistBG(char)
	local root = char and char:FindFirstChild("HumanoidRootPart"); if not root then return end
	local bg = root:FindFirstChild("_DistBG")
	if not bg then
		bg = Instance.new("BillboardGui"); bg.Name = "_DistBG"
		bg.Size = UDim2.new(0, 60, 0, 16); bg.StudsOffset = Vector3.new(0, 3.5, 0)
		bg.AlwaysOnTop = true; bg.Parent = root
		local lb = Instance.new("TextLabel"); lb.Name = "D"; lb.Size = UDim2.new(1,0,1,0)
		lb.BackgroundTransparency = 1; lb.TextColor3 = Color3.fromRGB(80, 200, 255)
		lb.TextSize = 11; lb.Font = Enum.Font.GothamBold; lb.Text = "?m"; lb.Parent = bg
	end
	return bg
end

local function createTrail()
	local root = getChar() and getChar():FindFirstChild("HumanoidRootPart"); if not root then return end
	if trail then trail:Destroy(); trail = nil end
	local a0 = Instance.new("Attachment"); a0.Position = Vector3.new(0,1,0); a0.Parent = root
	local a1 = Instance.new("Attachment"); a1.Position = Vector3.new(0,-1,0); a1.Parent = root
	trail = Instance.new("Trail"); trail.Attachment0 = a0; trail.Attachment1 = a1
	trail.Lifetime = 0.7; trail.MinLength = 0; trail.Parent = root
end

