	ind.BorderSizePixel = 0; ind.ZIndex = 7; ind.Parent = btn
	tabBtns[name] = {btn = btn, ind = ind}
	btn.MouseEnter:Connect(function()
		if activeTab ~= name then tw(btn, {TextColor3 = Color3.fromRGB(165, 170, 200)}, 0.12) end
	end)
	btn.MouseLeave:Connect(function()
		if activeTab ~= name then tw(btn, {TextColor3 = Color3.fromRGB(100, 105, 128)}, 0.12) end
	end)
end

local function switchTab(name)
	if activeTab == name then return end
	activeTab = name
	for _, n in ipairs(tabNames) do
		local on = (n == name)
		tabFrames[n].Visible = on
		-- индикатор: активный = полная ширина кнопки снизу, неактивный = скрыт
		tabBtns[n].ind.Size     = on and UDim2.new(1, -8, 0, 2) or UDim2.new(0, 0, 0, 2)
		tabBtns[n].ind.Position = on and UDim2.new(0, 4, 1, -2) or UDim2.new(0.5, 0, 1, -2)
		tabBtns[n].btn.TextColor3 = on and Color3.fromRGB(70, 140, 255) or Color3.fromRGB(100, 105, 128)
		tabBtns[n].btn.Font = on and Enum.Font.SourceSansBold or Enum.Font.SourceSansSemibold
	end
end

for _, name in ipairs(tabNames) do
	local cap = name
	tabBtns[name].btn.MouseButton1Click:Connect(function() switchTab(cap) end)
end

