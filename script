UserInputService.InputBegan:Connect(function(inp, gpe)
	if gpe then return end

	-- M → разблокировать/заблокировать курсор
	if inp.KeyCode == Enum.KeyCode.M then
		State.CursorUnlock = not State.CursorUnlock
		if State.CursorUnlock then
			UserInputService.MouseBehavior = Enum.MouseBehavior.Default
			UserInputService.MouseIconEnabled = true
			notify("Курсор: разблокирован (M — закрыть)", Color3.fromRGB(90, 210, 140))
		else
			UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
			UserInputService.MouseIconEnabled = false
			notify("Курсор: заблокирован", Color3.fromRGB(180, 80, 80))
		end
		return
	end

	-- CapsLock → авто-прыжок
	if inp.KeyCode == Enum.KeyCode.CapsLock then
		local s = ToggleSetters["AutoJump"]
		if s then s(not State.AutoJump) end
		return
	end

	-- Пользовательские клавиши для функций
	local function tryToggle(bindKey, stateKey)
		if bindMatches(Keybinds[bindKey], inp) then
			local s = ToggleSetters[stateKey]
			if s then s(not State[stateKey]) end
			return true
		end
		return false
	end
	if tryToggle("AutoJump","AutoJump") then return end
	if tryToggle("SpeedHack","SpeedHack") then return end
	if tryToggle("InfiniteJump","InfiniteJump") then return end
	if tryToggle("BunnyHop","BunnyHop") then return end
	if tryToggle("SlopeBounce","SlopeBounce") then return end

	-- Авто Дэш
	local DASH = _G._AP_DASH
	if DASH and DASH.enabled and DASH.bind and inp.KeyCode == DASH.bind then
		task.spawn(function()
			-- 1. Зажать Ctrl
			local vs = game:GetService("VirtualInputManager") or nil
			-- Используем keydown через UserInputService simulation
			-- Ctrl
			local function pressKey(kc)
				local ui = UserInputService
				-- Симулируем через InputObject (работает в Studio)
				local fakeInp = {KeyCode = kc, UserInputType = Enum.UserInputType.Keyboard}
				-- Нет прямого способа симулировать — используем Humanoid для прыжка
				-- и VirtualInputManager для Ctrl/G/digit если доступен
			end

			local char2 = getChar()
			local hum2 = char2 and char2:FindFirstChild("Humanoid")
			local root2 = char2 and char2:FindFirstChild("HumanoidRootPart")
			if not hum2 or not root2 then return end

			-- Авто-прыжок если включён "не касаться пола"
			if DASH.noFloor then
				hum2:ChangeState(Enum.HumanoidStateType.Jumping)
				if root2 then
					root2.AssemblyLinearVelocity = Vector3.new(
						root2.AssemblyLinearVelocity.X, CONFIG.AutoJumpHeight, root2.AssemblyLinearVelocity.Z)
				end
			end

			task.wait(0.05)

			-- Нажать G (дэш в Evade)
			-- VirtualInputManager доступен только в Studio, пробуем
			local vim = game:GetService("VirtualInputManager")
			if vim then
				vim:SendKeyEvent(true,  Enum.KeyCode.LeftControl, false, game)
				task.wait(0.04)
				vim:SendKeyEvent(true,  Enum.KeyCode.G,           false, game)
				task.wait(0.06)
				vim:SendKeyEvent(false, Enum.KeyCode.G,           false, game)
				task.wait(0.05)
				-- Нажать цифру слота
				local digitKey = ({"One","Two","Three","Four","Five","Six"})[DASH.digit]
				if digitKey then
					vim:SendKeyEvent(true,  Enum.KeyCode[digitKey], false, game)
					task.wait(0.05)
					vim:SendKeyEvent(false, Enum.KeyCode[digitKey], false, game)
				end
				task.wait(0.05)
				vim:SendKeyEvent(false, Enum.KeyCode.LeftControl, false, game)
			end

			notify("Дэш активирован! Слот " .. DASH.digit, Color3.fromRGB(255,160,40))
		end)
		return
	end

	-- Стоп реплея
	if bindMatches(Keybinds["StopReplay"], inp) and ReplayActive then
		ReplayActive = false
		local rs = _G._AP_recStatus
		if rs then rs.TextColor3 = Color3.fromRGB(170, 45, 45); rs.Text = "⏹ Реплей остановлен" end
		notify("Ghost Replay: остановлен", Color3.fromRGB(200, 65, 65))
		return
	end

	-- V → запись
	if inp.KeyCode == RecordKeybind then
		if not State.Recording then
			State.Recording = true; RecordedFrames = {}
			local rs = _G._AP_recStatus
			if rs then rs.TextColor3 = Color3.fromRGB(200,60,60); rs.Text = "⏺ Запись... (V — стоп)" end
			notify("Запись начата — V остановить", Color3.fromRGB(200,60,60))
		else
			State.Recording = false; State.HasRecord = #RecordedFrames > 0
			local rs = _G._AP_recStatus
			if rs then rs.TextColor3 = Color3.fromRGB(55,200,100)
				rs.Text = "✔ Готово (" .. #RecordedFrames .. " кадров)  B — воспроизвести" end
			notify("Запись сохранена! " .. #RecordedFrames .. " кадров", Color3.fromRGB(55,200,100))
		end
		return
	end

	-- B → воспроизвести
	if inp.KeyCode == ReplayKeybind and State.HasRecord and not ReplayActive then
		ReplayActive = true
		local rs = _G._AP_recStatus
		if rs then rs.TextColor3 = Color3.fromRGB(70,140,255); rs.Text = "▶ Воспроизведение..." end
		notify("Ghost Replay: старт", Color3.fromRGB(70,140,255))
		task.spawn(function()
			local char = getChar()
			local hum2 = char and char:FindFirstChild("Humanoid")
			local savedWS = hum2 and hum2.WalkSpeed or 16
			local savedJP = hum2 and hum2.JumpPower  or 50
			if hum2 then hum2.WalkSpeed = 0; hum2.JumpPower = 0 end
			-- Используем Heartbeat для точного воспроизведения (без lag от task.wait)
			local frameIdx = 1
			local elapsed = 0
			local conn
			conn = RunService.Heartbeat:Connect(function(dt)
				if not ReplayActive or frameIdx > #RecordedFrames then
					conn:Disconnect()
					ReplayActive = false
					if hum2 then hum2.WalkSpeed = savedWS; hum2.JumpPower = savedJP end
					if rs then rs.TextColor3 = Color3.fromRGB(55,200,100); rs.Text = "✔ Завершено   B — повторить" end
					notify("Ghost Replay: завершён", Color3.fromRGB(55,200,100))
					return
				end
				elapsed = elapsed + dt
				while frameIdx <= #RecordedFrames and elapsed >= 0 do
					local frame = RecordedFrames[frameIdx]
					local root2 = getChar() and getChar():FindFirstChild("HumanoidRootPart")
					if root2 then root2.CFrame = frame.CFrame end
					elapsed = elapsed - frame.dt
					frameIdx = frameIdx + 1
				end
			end)
		end)
	end
end)

