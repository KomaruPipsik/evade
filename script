local function makeTabFrame(name)
	local f = Instance.new("ScrollingFrame")
	f.Name = name; f.Size = UDim2.new(1, 0, 1, 0); f.Position = UDim2.new(0, 0, 0, 0)
	f.BackgroundTransparency = 1; f.BorderSizePixel = 0
	f.ScrollBarThickness = 3; f.ScrollBarImageColor3 = Color3.fromRGB(60, 120, 255)
	f.Visible = false; f.ZIndex = 2; f.Parent = contentZone
	local ll = Instance.new("UIListLayout"); ll.Padding = UDim.new(0, 5)
	ll.SortOrder = Enum.SortOrder.LayoutOrder; ll.Parent = f
	local lp = Instance.new("UIPadding"); lp.PaddingLeft = UDim.new(0, 9); lp.PaddingRight = UDim.new(0, 9)
	lp.PaddingTop = UDim.new(0, 7); lp.PaddingBottom = UDim.new(0, 10); lp.Parent = f
	ll:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		f.CanvasSize = UDim2.new(0, 0, 0, ll.AbsoluteContentSize.Y + 16)
	end)
	return f
end

