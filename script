local lastPos = nil
local spinAngle = 0
local fakelagTimer = 0
local rainbowHue = 0
local trail = nil

-- Создание следа
local function createTrail()
	if not Character or not RootPart then return end
	if trail then trail:Destroy() end
	local att0 = Instance.new("Attachment", RootPart)
	att0.Position = Vector3.new(0, 1, 0)
	local att1 = Instance.new("Attachment", RootPart)
	att1.Position = Vector3.new(0, -1, 0)
	trail = Instance.new("Trail")
	trail.Attachment0 = att0
	trail.Attachment1 = att1
	trail.Lifetime = 0.8
	trail.MinLength = 0
	trail.Parent = RootPart
end

RunService.Heartbeat:Connect(function(dt)
	-- обновить ссылки
	Character = Player.Character
	if not Character then return end
	local hum = Character:FindFirstChild("Humanoid")
	local root = Character:FindFirstChild("HumanoidRootPart")
	if not hum or not root then return end

	-- Запись движений
	if State.Recording then
		local prev = lastPos
		lastPos = root.CFrame
		table.insert(RecordedFrames, {CFrame = root.CFrame, dt = dt})
	end

	-- Авто-прыжок у пола
	if State.AutoJump then
		local ray = workspace:Raycast(root.Position, Vector3.new(0,-CONFIG.AutoJumpThreshold,0))
		if ray and hum.FloorMaterial ~= Enum.Material.Air then
			hum:ChangeState(Enum.HumanoidStateType.Jumping)
			root.AssemblyLinearVelocity = Vector3.new(
				root.AssemblyLinearVelocity.X,
				CONFIG.AutoJumpHeight,
				root.AssemblyLinearVelocity.Z
			)
		end
	end

	-- Bunny Hop
	if State.BunnyHop and hum.FloorMaterial ~= Enum.Material.Air then
		hum:ChangeState(Enum.HumanoidStateType.Jumping)
	end

	-- Spinbot
	if State.Spinbot then
		spinAngle = (spinAngle + 8) % 360
		root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(spinAngle), 0)
	end

	-- Fake Lag
	if State.FakeLag then
		fakelagTimer = fakelagTimer + dt
		if fakelagTimer >= 0.1 then
			fakelagTimer = 0
			task.wait(0.05)
		end
	end

	-- Rainbow Trail
	if State.RainbowTrail then
		if not trail or not trail.Parent then createTrail() end
		rainbowHue = (rainbowHue + dt * 0.5) % 1
		if trail then
			trail.Color = ColorSequence.new{
				ColorSequenceKeypoint.new(0, Color3.fromHSV(rainbowHue, 1, 1)),
				ColorSequenceKeypoint.new(1, Color3.fromHSV((rainbowHue+0.5)%1, 1, 1))
			}
		end
	elseif trail and trail.Parent then
		trail:Destroy()
		trail = nil
	end

	-- ESP рендер
	if State.PlayerESP or State.BotESP or State.DistanceESP then
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= Player and p.Character then
				local pr = p.Character:FindFirstChild("HumanoidRootPart")
				if pr then
					-- подсветка через SelectionBox
					local box = pr:FindFirstChild("_ESPBox")
					if not box then
						box = Instance.new("SelectionBox")
						box.Name = "_ESPBox"
						box.Adornee = p.Character
						box.Parent = pr
					end
					if State.PlayerESP then
						box.Color3 = Color3.fromRGB(80,200,255)
						box.LineThickness = 0.05
						box.SurfaceTransparency = 0.85
						box.SurfaceColor3 = Color3.fromRGB(80,200,255)
						box.Visible = true
					elseif box then
						box.Visible = false
					end
				end
			end
		end
	end
end)

